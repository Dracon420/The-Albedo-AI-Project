# --- Local directory paths ---
# Absolute path to your Chaotic 3D files (STLs, gcode, slicer configs)
CHAOTIC_3D_PATH=C:\path\to\Chaotic 3D

# Absolute path to your Exotic OS Python code and logs
EXOTIC_OS_PATH=C:\path\to\Exotic OS

# --- ChromaDB ---
# Where the persistent vector database is stored (kept out of git)
CHROMA_DB_PATH=./chroma_db

# --- Ollama ---
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# --- Albedo behaviour ---
RAG_TOP_K=5
WEB_SEARCH_MAX_RESULTS=5

# --- Audio / Voice ---
# Download Piper from: https://github.com/rhasspy/piper/releases
# Download a voice from: https://huggingface.co/rhasspy/piper-voices
PIPER_BINARY=C:\piper\piper.exe
PIPER_VOICE_MODEL=C:\piper\voices\en_US-ryan-high.onnx

# Wake word: path to a custom Cortana .onnx, or a built-in label like "hey_jarvis"
# Train a custom model: https://github.com/dscripka/openWakeWord#training-new-models
WAKEWORD_MODEL=hey_jarvis
WAKEWORD_THRESHOLD=0.5

# Faster-Whisper — tuned for RTX 2060 6 GB alongside Ollama
# int8_float16 keeps Whisper VRAM under 1 GB; raise to float16 after 32 GB RAM upgrade
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8_float16

# VAD silence gate (seconds of quiet before Albedo stops listening)
VAD_SILENCE_DURATION=1.5
VAD_SILENCE_THRESHOLD=0.01
VAD_MAX_RECORD_SECONDS=30

WAKE_ACK_PHRASE=Yes?
