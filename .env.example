# --- Local directory paths ---
CHAOTIC_3D_PATH=D:\Chaotic 3D
EXOTIC_OS_PATH=D:\Exotic OS

# --- Obsidian Vault (set by onboarding wizard or manually) ---
OBSIDIAN_VAULT_PATH=

# --- ChromaDB ---
CHROMA_DB_PATH=./chroma_db

# --- Ollama ---
# Standard (RTX 2060 / 6 GB VRAM)
OLLAMA_MODEL=llama3.2:3b
# High-Spec (RTX 3080+ / 8 GB+ VRAM) — swap to:
# OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Albedo behaviour ---
# Standard
RAG_TOP_K=5
# High-Spec: RAG_TOP_K=10
WEB_SEARCH_MAX_RESULTS=5

# --- Audio / Voice ---
# Download Piper binary: https://github.com/rhasspy/piper/releases
# Download voice model:  https://huggingface.co/rhasspy/piper-voices
PIPER_BINARY=C:\piper\piper.exe
PIPER_VOICE_MODEL=C:\piper\voices\en_US-ryan-high.onnx

# --- Vosk STT (replaces faster-whisper + openwakeword) ---
# Default model is downloaded by setup_utility.py to:
#   ./vosk_models/vosk-model-small-en-us-0.15  (~40 MB)
# Set this only if you want to point at a different model directory.
VOSK_MODEL_PATH=

# Wake word(s) — comma-separated list. Vosk listens with a restricted
# grammar of just these words plus "[unk]" for low CPU usage.
WAKE_WORDS=cortana,jarvis

# --- VAD ---
VAD_SILENCE_DURATION=1.2
VAD_SILENCE_THRESHOLD=0.01
VAD_MAX_RECORD_SECONDS=30

WAKE_ACK_PHRASE=Yes?

# --- Swarm Matrix API Keys ---
# Obtain keys from the respective provider dashboards.
# Leave blank if not using a provider — Albedo will skip that client.
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
