# --- Local directory paths ---
CHAOTIC_3D_PATH=D:\Chaotic 3D
EXOTIC_OS_PATH=D:\Exotic OS

# --- Obsidian Vault (set by onboarding wizard or manually) ---
OBSIDIAN_VAULT_PATH=

# --- ChromaDB ---
CHROMA_DB_PATH=./chroma_db

# --- Ollama ---
# Standard (RTX 2060 / 6 GB VRAM)
OLLAMA_MODEL=llama3.2:3b
# High-Spec (RTX 3080+ / 8 GB+ VRAM) — swap to:
# OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Albedo behaviour ---
# Standard
RAG_TOP_K=5
# High-Spec: RAG_TOP_K=10
WEB_SEARCH_MAX_RESULTS=5

# --- Audio / Voice ---
# Engine selector — controls which TTS backend synthesize_to_bytes() uses.
# Valid values: "piper" (default, v2.x), "kokoro" (high-quality offline ONNX)
# When set to "kokoro", Kokoro is tried first and Piper is the fallback.
AUDIO_TTS=piper

# Download Piper binary: https://github.com/rhasspy/piper/releases
# Download voice model:  https://huggingface.co/rhasspy/piper-voices
PIPER_BINARY=C:\piper\piper.exe
PIPER_VOICE_MODEL=C:\piper\voices\en_US-ryan-high.onnx

# --- Kokoro TTS (optional, enabled by AUDIO_TTS=kokoro) ---
# Download the model + voices files from:
#   https://github.com/thewh1teagle/kokoro-onnx/releases
# Place them in <install>/voices/ or set explicit paths below.
# Default voice is "af_sky"; full list at the project README.
# KOKORO_MODEL_PATH=C:/Albedo/voices/kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=C:/Albedo/voices/voices-v1.0.bin
# KOKORO_VOICE=af_sky
# KOKORO_SPEED=1.0

# --- UI selector (Phase 2 alpha) ---
# Controls which user interface gui.main() launches.
#   tk   (default, v2.x) — the CustomTkinter Mission Control window
#   eel                   — the new HTML/CSS/JS Cyberdeck UI (alpha)
# Falls back to Tk silently if eel is not installed.
ALBEDO_UI=tk

# --- STT engine selector (Phase 4 N+2) ---
# Controls which speech-to-text backend albedo/audio/stt.py dispatches to.
# Valid values:
#   vosk     (default, v2.x) — offline Kaldi model, ~40 MB, zero VRAM
#   deepgram                  — cloud STT via Deepgram REST, with whisper
#                               as the offline failsafe. Requires
#                               DEEPGRAM_API_KEY below.
#   whisper                   — distil-whisper offline only; skips the
#                               cloud entirely. Slow on CPU (~0.7x realtime).
AUDIO_STT=vosk

# --- Vosk STT ---
# Default model path is derived automatically from the install location.
# Override only if you moved the model to a custom directory.
# VOSK_MODEL_PATH=C:\Albedo\vosk_models\vosk-model-small-en-us-0.15

# --- Deepgram cloud STT (used when AUDIO_STT=deepgram) ---
# Get a key from https://console.deepgram.com (free tier: ~$200 credit).
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2          # nova-2 = lowest latency English model
# DEEPGRAM_LANGUAGE=en
# DEEPGRAM_TIMEOUT=10            # seconds

# --- Whisper offline STT (used as Deepgram fallback or stand-alone) ---
# The distil-small.en model is downloaded by faster-whisper on first
# transcribe() call. No env var needed unless you want to log routing:
# STT_ROUTER_AUDIT=1             # write logs/stt_router.log on every call

# Wake word(s) — comma-separated list. Vosk listens with a restricted
# grammar of just these words plus "[unk]" for low CPU usage.
WAKE_WORDS=cortana,jarvis

# --- VAD ---
VAD_SILENCE_DURATION=1.2
VAD_SILENCE_THRESHOLD=0.01
VAD_MAX_RECORD_SECONDS=30

WAKE_ACK_PHRASE=Yes?

# --- Dream cycle / Idle detection ---
# IDLE_THRESHOLD_MINUTES=20    # Minutes of inactivity before dream fires (default 20)
# IDLE_POLL_INTERVAL_S=30      # How often the idle monitor checks (default 30 s)
# IDLE_COOLDOWN_MINUTES=120    # Minimum gap between dream cycles (default 120 min)

# Directories the file organizer scans during dream (semicolon-separated)
# Default: Desktop and Downloads
# DREAM_SCAN_DIRS=C:\Users\YourName\Desktop;C:\Users\YourName\Downloads

# Root folder where organized files are placed (default: Documents\Albedo-Organized)
# DREAM_TARGET_ROOT=C:\Users\YourName\Documents\Albedo-Organized

# Set to 1 to use Ollama to classify files with unknown extensions (slower, more accurate)
# DREAM_AI_CLASSIFY=0

# --- Swarm Matrix API Keys ---
# Obtain keys from the respective provider dashboards.
# Leave blank if not using a provider — Albedo will skip that client.
GEMINI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
