# --- Local directory paths ---
# Absolute path to your Chaotic 3D files (STLs, gcode, slicer configs)
CHAOTIC_3D_PATH=C:\path\to\Chaotic 3D

# Absolute path to your Exotic OS Python code and logs
EXOTIC_OS_PATH=C:\path\to\Exotic OS

# --- ChromaDB ---
# Where the persistent vector database is stored (kept out of git)
CHROMA_DB_PATH=./chroma_db

# --- Ollama ---
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# --- Albedo behaviour ---
# Number of RAG chunks returned per collection per query
RAG_TOP_K=5
# Number of web search results fetched during Verify
WEB_SEARCH_MAX_RESULTS=5
