# --- Local directory paths ---
CHAOTIC_3D_PATH=D:\Chaotic 3D
EXOTIC_OS_PATH=D:\Exotic OS

# --- Obsidian Vault (Claude's Brain + Albedo RAG) ---
# Used by: ChromaDB RAG indexer (Albedo searches your notes)
#          Claude Code memory sync (albedo/tools/sync_brain.py)
OBSIDIAN_VAULT_PATH=C:\Users\demon\Desktop\Albedo Project Brain
# Note: Claude Code's memory vault is separate (Claudes Brain) and is
# NOT controlled by OBSIDIAN_VAULT_PATH. Albedo's RAG only uses the path above.

# --- ChromaDB ---
CHROMA_DB_PATH=./chroma_db

# --- Ollama ---
# Azure-trained 7B fine-tuned personas (primary — wake word routes automatically)
OLLAMA_MODEL=albedo-cortana-8b
# Available models registered with Ollama:
#   albedo-cortana-8b  — Qwen2.5-7B fine-tuned on Cortana persona (Azure T4 training)
#   albedo-jarvis-8b   — Qwen2.5-7B fine-tuned on JARVIS persona  (Azure T4 training)
#   albedo-cortana     — legacy 1.9 GB baseline (fallback only)
#   albedo-jarvis      — legacy 1.9 GB baseline (fallback only)
OLLAMA_BASE_URL=http://localhost:11434

# --- Albedo behaviour ---
# Standard
RAG_TOP_K=5
# High-Spec: RAG_TOP_K=10
WEB_SEARCH_MAX_RESULTS=5

# --- Audio / Voice ---
# TTS waterfall (runs in order, skips unavailable tiers automatically):
#   Tier 0: Azure Neural TTS (CortanaNeural)  — if AZURE_SPEECH_KEY set
#   Tier 1: XTTS-v2 voice clone (local)       — if XTTS_VOICE_SAMPLE set
#   Tier 2: Edge-TTS (cloud, no key)           — always available w/ internet
#   Tier 3: Kokoro ONNX                        — if AUDIO_TTS=kokoro
#   Tier 4: Piper (offline, always works)      — final fallback
# AUDIO_TTS controls the Kokoro/Piper leg only:
#   "piper"  (default) — Edge → Piper
#   "kokoro"           — Edge → Kokoro → Piper
AUDIO_TTS=piper

# Download Piper binary: https://github.com/rhasspy/piper/releases
# Download voice model:  https://huggingface.co/rhasspy/piper-voices
PIPER_BINARY=C:\piper\piper.exe
PIPER_VOICE_MODEL=C:\piper\voices\en_US-ryan-high.onnx

# --- Kokoro TTS (optional, enabled by AUDIO_TTS=kokoro) ---
# Download the model + voices files from:
#   https://github.com/thewh1teagle/kokoro-onnx/releases
# Place them in <install>/voices/ or set explicit paths below.
# Default voice is "af_sky"; full list at the project README.
# KOKORO_MODEL_PATH=C:/Albedo/voices/kokoro-v1.0.onnx
# KOKORO_VOICES_PATH=C:/Albedo/voices/voices-v1.0.bin
# KOKORO_VOICE=af_sky
# KOKORO_SPEED=1.0

# --- UI selector ---
# Controls which user interface gui.main() launches.
#   eel  (default) — HTML/CSS/JS Cyberdeck UI (Mission Control)
#   tk              — legacy CustomTkinter window (fallback only)
ALBEDO_UI=eel

# --- STT engine selector ---
# Controls which speech-to-text backend albedo/audio/stt.py dispatches to.
# Each cloud tier auto-cascades to the next on failure, ending at Vosk.
# Valid values:
#   vosk     (default) — offline Kaldi model, ~40 MB, zero VRAM, always works
#   azure              — Azure Speech STT (5 hrs/month free) → Groq → Vosk
#                        Requires AZURE_SPEECH_KEY + AZURE_SPEECH_REGION above.
#   groq               — Groq Whisper API (whisper-large-v3-turbo) → Vosk
#                        Requires GROQ_API_KEY in the Tier 1 section above.
#   deepgram           — Deepgram cloud STT, whisper offline fallback.
#                        Requires DEEPGRAM_API_KEY below.
#   whisper            — distil-whisper offline only; skips all cloud.
AUDIO_STT=vosk

# --- Vosk STT ---
# Default model path is derived automatically from the install location.
# Override only if you moved the model to a custom directory.
# VOSK_MODEL_PATH=C:\Albedo\vosk_models\vosk-model-small-en-us-0.15

# --- Deepgram cloud STT (used when AUDIO_STT=deepgram) ---
# Get a key from https://console.deepgram.com (free tier: ~$200 credit).
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2          # nova-2 = lowest latency English model
# DEEPGRAM_LANGUAGE=en
# DEEPGRAM_TIMEOUT=10            # seconds

# --- Whisper offline STT (used as Deepgram fallback or stand-alone) ---
# The distil-small.en model is downloaded by faster-whisper on first
# transcribe() call. No env var needed unless you want to log routing:
# STT_ROUTER_AUDIT=1             # write logs/stt_router.log on every call

# Wake word(s) — comma-separated list. Vosk listens with a restricted
# grammar of just these words plus "[unk]" for low CPU usage.
WAKE_WORDS=cortana,jarvis

# --- VAD ---
VAD_SILENCE_DURATION=1.2
VAD_SILENCE_THRESHOLD=0.01
VAD_MAX_RECORD_SECONDS=30

WAKE_ACK_PHRASE=Yes?

# --- Dream cycle / Idle detection ---
# IDLE_THRESHOLD_MINUTES=20    # Minutes of inactivity before dream fires (default 20)
# IDLE_POLL_INTERVAL_S=30      # How often the idle monitor checks (default 30 s)
# IDLE_COOLDOWN_MINUTES=120    # Minimum gap between dream cycles (default 120 min)

# Directories the file organizer scans during dream (semicolon-separated)
# Default: Desktop and Downloads
# DREAM_SCAN_DIRS=C:\Users\YourName\Desktop;C:\Users\YourName\Downloads

# Root folder where organized files are placed (default: Documents\Albedo-Organized)
# DREAM_TARGET_ROOT=C:\Users\YourName\Documents\Albedo-Organized

# Set to 1 to use Ollama to classify files with unknown extensions (slower, more accurate)
# DREAM_AI_CLASSIFY=0

# ============================================================================
# TIER 0 — Azure (Optional, highest quality, free quotas)
# ============================================================================
# Albedo uses your own Azure keys — no shared quota, no subscription needed.
# Create a free Azure account: https://azure.microsoft.com/free/
# (no credit card required for free-tier services)

# --- Azure Speech (TTS + STT) ---
# Free tier: 500,000 Neural TTS chars/month + 5 hrs STT/month
# Create resource: portal.azure.com → Create resource → Speech
# en-US-CortanaNeural is the real Cortana voice from Windows/Halo lore.
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
# AZURE_TTS_VOICE_CORTANA=en-US-CortanaNeural
# AZURE_TTS_VOICE_JARVIS=en-US-GuyNeural
# AZURE_TTS_STYLE=                         # optional: cheerful, sad, empathetic, etc.
# AZURE_STT_LANGUAGE=en-US

# --- Azure OpenAI (LLM — optional, user's own deployment) ---
# Works with any Azure OpenAI model: GPT-3.5, GPT-4, Phi-3.5 Mini, etc.
# Phi-3.5 Mini Instruct is serverless + very cheap (~$0.13/M tokens).
# Create: portal.azure.com → Azure OpenAI → Deploy a model
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo
# AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================================
# TIER 1 — Free cloud APIs (generous free tiers, no credit card)
# ============================================================================

# --- Swarm Matrix API Keys ---
# Obtain keys from the respective provider dashboards.
# Leave blank if not using a provider — Albedo will skip that client.
GEMINI_API_KEY=
# gemini-2.0-flash recommended (better quality than flash-lite, same free quota)
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
TOGETHER_API_KEY=

# --- Web Search Enhancement (free tiers) ---
# Tavily — AI-optimised structured search, 1,000 queries/month free
# Sign up: https://app.tavily.com  (takes ~30 seconds)
# When set, replaces DuckDuckGo as the primary web search backend.
TAVILY_API_KEY=

# Wolfram Alpha Short Answers — math, unit conversions, physical constants
# 2,000 queries/month free (no credit card required)
# Sign up: https://developer.wolframalpha.com → Get an App ID
# When set, computation queries bypass the LLM entirely for exact answers.
WOLFRAM_API_KEY=
# Wikipedia is always enabled — no key required.

# ============================================================================
# TIER 2 — Local voice clone (optional, fully offline, $0)
# ============================================================================

# --- XTTS-v2 local voice clone ---
# Clone any voice from a 6-second WAV reference clip.
# Install: pip install TTS   (downloads ~1.8 GB model on first use)
# Record a clean 6-second clip of your target voice → save as .wav
# Set XTTS_VOICE_SAMPLE to enable. Falls back to Edge-TTS when unset.
# XTTS_VOICE_SAMPLE=C:/path/to/voice_reference.wav
# XTTS_DEVICE=cuda     # or "cpu". Auto-detects GPU if not set.
