# Environment & secrets
.env
.env.*
*.env
!.env.example

# ChromaDB vector database
chroma/
chroma_db/
vectorstore/
*.chroma

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# Inno Setup build artifacts
Output/
Albedo-Setup.exe

# Stray files from botched pip commands (e.g. shell typo creating "=1.4.0")
=*

# Runtime-generated memory database
albedo_memory_db/

# First-boot hardware profile cache (per-machine, regenerated by hardware_profile.py)
hardware_config.json

# Auto-generated webhook shared secret (per-machine, regenerated by webhook.py)
.webhook_secret

# Ollama model cache (large binaries)
models/
*.gguf
*.bin

# Vosk STT model (downloaded by setup_utility.py)
vosk_models/
*.pt

# Piper TTS binary and voice models (downloaded by installer — not committed)
piper/
voices/

# Claude Code local settings
.claude/

# Audio scratch files
*.wav
*.mp3
*.ogg

# OS
Thumbs.db
.DS_Store
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# React Native / Expo
albedo-mobile/node_modules/
albedo-mobile/.expo/
albedo-mobile/android/
albedo-mobile/ios/

# Training virtual environment (never commit — regenerated by train_local.py setup)
training_venv/

# LoRA adapters and merged models (large safetensors — stored outside repo)
outputs/

# llama.cpp pre-built binaries and zip (large DLLs/EXEs)
azure_training/llama_bins/
azure_training/llama_bins.zip
azure_training/llama_cpp_full/

# Installer EXEs in root (Output/ already ignored; root-level exes are build artifacts)
*.exe

# Logs
logs/

# Local Claude Code settings (machine-specific)
.claude/settings.local.json
